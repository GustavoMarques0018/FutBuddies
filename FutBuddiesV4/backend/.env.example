# ============================================================
#  FutBuddies Backend - Variáveis de Ambiente (TEMPLATE)
#  Copia para .env e preenche com valores reais. NÃO commitar.
# ============================================================

# Ambiente: development | production
NODE_ENV=development
PORT=5000

# ── Base de dados (SQL Server / Azure SQL) ─────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=FutBuddiesDB
DB_USER=sa
DB_PASSWORD=changeme
# Em Azure SQL coloca DB_ENCRYPT=true
DB_ENCRYPT=false
DB_TRUST_CERT=true

# ── JWT (OBRIGATÓRIO em produção) ──────────────────────────
# Gera com:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ───────────────────────────────────────────────────
# Em produção é OBRIGATÓRIO. Lista separada por vírgulas.
# Exemplo: https://app.futbuddies.pt,https://www.futbuddies.pt
CORS_ORIGIN=

# ── Stripe (pagamentos) ───────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_COMISSAO_PCT=15
APP_BASE_URL=http://localhost:3000

# ── Web Push (notificações) ───────────────────────────────
# Gera com:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:admin@futbuddies.pt

# ── Email (opcional, mas recomendado) ─────────────────────
# Gmail: cria App Password em myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=teu-email@gmail.com
SMTP_PASS=app-password-de-16-chars
SMTP_FROM=FutBuddies <no-reply@futbuddies.pt>
