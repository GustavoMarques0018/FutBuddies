# ============================================================
#  FutBuddies Frontend - Variáveis de Ambiente (TEMPLATE)
#  Copia para .env e preenche. NÃO commitar com valores reais.
# ============================================================

# URL completo da API (incluir /api no final).
# OBRIGATÓRIO em produção. Em dev: http://localhost:5000/api
REACT_APP_API_URL=http://localhost:5000/api

# Stripe — chave PUBLISHABLE (segura no frontend)
REACT_APP_STRIPE_PUBLISHABLE_KEY=

# VAPID public key para web push (a mesma do backend)
REACT_APP_VAPID_PUBLIC_KEY=

# Servir em todas as interfaces (útil em dev para testar no telemóvel)
HOST=0.0.0.0
